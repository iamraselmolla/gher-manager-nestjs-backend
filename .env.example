# ============================================
# GHER ERP BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# ============================================

# --- App ---
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Database (plain PostgreSQL for now; swap DATABASE_URL to a Supabase
#     connection string later without any code changes) ---
DATABASE_URL="postgresql://gher_user:gher_pass@localhost:5432/gher_erp?schema=public"

# --- Redis (caching + BullMQ queues) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Auth ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# --- First-run seed (bootstrap SUPER_ADMIN, see prisma/seed.ts) ---
SEED_ADMIN_MOBILE=01700000000
SEED_ADMIN_PASSWORD=ChangeMe123
SEED_ADMIN_NAME=Super Admin

# --- i18n ---
DEFAULT_LANGUAGE=bn
SUPPORTED_LANGUAGES=bn,en

# --- Rate limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- File / Media storage (Supabase Storage or any S3-compatible bucket) ---
STORAGE_PROVIDER=local
STORAGE_BUCKET=gher-media
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
# Only used when STORAGE_PROVIDER=local — where uploaded files are written,
# and the base URL they're served back from (this API serves them itself).
STORAGE_LOCAL_DIR=./uploads
STORAGE_LOCAL_PUBLIC_BASE_URL=http://localhost:4000/api/v1/media/files

# --- Firebase Cloud Messaging (push notifications) ---
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
